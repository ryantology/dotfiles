# ---------------------------------------------------------------------------
# Homebrew
# ---------------------------------------------------------------------------

# Ensure Homebrew environment is set up (handles Apple Silicon vs Intel)
if [[ -f "/opt/homebrew/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/usr/local/bin/brew" ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# ---------------------------------------------------------------------------
# Zinit setup
# ---------------------------------------------------------------------------

# Auto-install zinit if not present
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  print -P "%F{33}Installing zinit...%f"
  mkdir -p "$(dirname $ZINIT_HOME)"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

# ---------------------------------------------------------------------------
# Plugins
# ---------------------------------------------------------------------------

zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting

# OMZ libs needed for theme and plugins
zinit snippet OMZL::async_prompt.zsh
zinit snippet OMZL::git.zsh
zinit snippet OMZL::theme-and-appearance.zsh
zinit snippet OMZL::prompt_info_functions.zsh

# OMZ plugins via snippets
zinit snippet OMZP::git
zinit snippet OMZP::history

# Prompt theme (robbyrussell - green arrow with git branch)
zinit snippet OMZT::robbyrussell

# ---------------------------------------------------------------------------
# Zsh options (replaces OMZ ENABLE_CORRECTION / COMPLETION_WAITING_DOTS)
# ---------------------------------------------------------------------------

setopt correct                # command auto-correction
setopt complete_in_word       # complete from both ends of a word
setopt always_to_end          # move cursor to end after completion

# Show dots while waiting for completion
expand-or-complete-with-dots() {
  print -Pn "%F{red}...%f"
  zle expand-or-complete
  zle redisplay
}
zle -N expand-or-complete-with-dots
bindkey "^I" expand-or-complete-with-dots

# ---------------------------------------------------------------------------
# PATH
# ---------------------------------------------------------------------------

declare -a dirs_to_prepend
dirs_to_prepend=(
  "/opt/homebrew/bin"
  "/opt/homebrew/sbin"
  "$HOME/dotfiles/bin"
  "$HOME/bin"
  "$HOME/.composer/vendor/bin"
  "$HOME/.local/bin"
)

PATH="/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin"
for dir in ${(k)dirs_to_prepend[@]}; do
  if [ -d "${dir}" ]; then
    PATH="${dir}:$PATH"
  fi
done

unset dirs_to_prepend
export PATH

# ---------------------------------------------------------------------------
# Shell dotfiles
# ---------------------------------------------------------------------------

for file in $HOME/.{shell_exports,shell_aliases,shell_functions,shell_config}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file"
done
unset file

# ---------------------------------------------------------------------------
# Tools
# ---------------------------------------------------------------------------

# Zoxide: smarter cd (use `z` to jump, or `cd` works as usual with smart matching)
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init --cmd cd zsh)"
fi

# fzf: fuzzy finder keybindings and completion
if command -v fzf &> /dev/null; then
  source <(fzf --zsh 2>/dev/null) || true
fi

# ---------------------------------------------------------------------------
# Local overrides
# ---------------------------------------------------------------------------

[ -f ~/.zsh.local ] && source ~/.zsh.local
